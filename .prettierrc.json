{
  "$schema": "https://json.schemastore.org/prettierrc",
  "quoteProps": "as-needed",
  "vueIndentScriptAndStyle": true,
  "singleAttributePerLine": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 120,
  "proseWrap": "preserve",
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false
}
