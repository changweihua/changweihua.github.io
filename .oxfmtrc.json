{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "quoteProps": "as-needed",
  "vueIndentScriptAndStyle": true,
  "singleAttributePerLine": true,
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 120,
  "proseWrap": "preserve",
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false,
  "sortPackageJson": false,
  "ignorePatterns": []
}
