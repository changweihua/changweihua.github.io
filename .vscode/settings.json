{
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  // 控制活动代码段是否阻止快速建议
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "window.dialogStyle": "custom",
  // 除了`Tab`键以外，`Enter`键是否同样可以接受建议
  // 这能减少“插入新行”和“接受建议”命令之间的歧义
  "editor.acceptSuggestionOnEnter": "smart",
  // 代码补全列表中，优先选择最近的建议
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "markdown.copyFiles.overwriteBehavior": "overwrite",
  "markdown.copyFiles.destination": {
    "/**/*": "/public/images/cmono-${fileName}"
  },
  "editor.fontFamily": "Maple Mono Normal NF CN,Maple Mono NF CN, JetBrains Maple Mono,Maple Mono SC NF", // 代码编辑器
  "terminal.integrated.fontFamily": "Maple Mono NF CN", // 终端
  "debug.console.fontFamily": "Maple Mono NF CN", // 调试控制台
  "markdown.preview.fontFamily": "Maple Mono NF CN", // Markdown预览
  "gitlens.views.fontFamily": "Maple Mono NF CN", // GitLens扩展视图（需安装GitLens）
  "workbench.tips.fontFamily": "Maple Mono NF CN", // 提示信息（部分版本无效）
  "workbench.desktopUI.fontFamily": "Maple Mono NF CN",
  "unocss.root": "packages/client",
  "workbench.fontAliasing": "antialiased", // 字体渲染方式（可选）
  // "window.titleBarStyle": "custom", // 启用自定义标题栏
  "workbench.experimental.settingsSandbox": true,
  "window.fontFamily": "Maple Mono NF CN", // 部分测试版本可能支持
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "index.html": "index.html,index.*.html,*.css",
    "package.json": ".nvmrc,.npmrc,tsconfig.*.json,*.cjs,*.js,*.json,*.config.ts,*.config.cjs,*.config.mjs,.preettierrc,.eslintrc.cjs,.eslintrc,.gitignore,.editorconfig,.node-version,.browserslistrc,.hintrc,licenses.csv,*.depcheckrc",
    ".env": "env.*,.env.*,.robots.*.txt",
    "components.d.ts": "auto-imports.d.ts,components.d.ts",
    "index.md": "index.md,login.md,archives.md,tags.md,about-*.md,me.*.md,manuals.md,resume.md,about.md,en-US.md,zh-CN.md,sponsor.md,CONTRIBUTING.md,CODE_OF_CONDUCT.md,CONTRIBUTING.zh-CN.md,README.md,CHANGELOG.md,PRIVACY_POLICY.md,TERMS_OF_SERVICE.md,logo.svg",
    "Dockerfile": "Dockerfile, .dockerignore"
  },
  "workbench.colorCustomizations": {
    // "terminal.background": "#ffffff",
    "minimap.background": "#ffffff"
  },
  "apc.electron": {
    "frame": false,
    "titleBarStyle": "hidden"
  },
  "window.titleBarStyle": "native",
  "window.customTitleBarVisibility": "never",
  "png-to-webp.quality": 100,
  "png-to-webp.deleteOriginalAfterConversion": false,
  "workbench.navigationControl.enabled": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.preferences.importModuleSpecifier": "relative",
  // settings.json
  "editor.linkedEditing": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "git.blame.editorDecoration.template": "${subject}, ${authorName} (${authorDateAgo})",
  "terminal.integrated.fontLigatures": true,
  "files.trimTrailingWhitespace": true,
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "terminal.integrated.shellArgs.windows": [],
  "javascript.updateImportsOnFileMove.enabled": "prompt",
  "typescript.updateImportsOnFileMove.enabled": "prompt",
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.mouseWheelZoom": true,
  "editor.renderWhitespace": "boundary",
  "editor.smoothScrolling": true,
  "editor.wordWrap": "on",
  "files.autoGuessEncoding": true,
  "terminal.integrated.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.wrapTabs": true,
  "iconify.customCollectionJsonPaths": [
    "node_modules/.unplugin-iconify-generator/cmono.json"
  ],
  "vue.server.maxOldSpaceSize": 4096,
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.nodePath": "node",
  "vitest.shellType": "terminal",
  "commentTranslate.targetLanguage": "zh-CN",
  "commentTranslate.hover.enabled": true,
  "cssvar.files": [
    "./node_modules/open-props/open-props.min.css",
    // if you have an alternative path to where your styles are located
    // you can add it in this array of files
    "assets/styles/variables.css"
  ],

  // Do not ignore node_modules css files, which is ignored by default
  "cssvar.ignore": [],

  // add support for autocomplete in JS or JS like files
  "cssvar.extensions": [
    "css",
    "postcss",
    "jsx",
    "tsx",
    "vue",
    "scss"
  ],

  // 开启扁平化配置
  "eslint.useFlatConfig": true,

  // 关闭默认的配置，我们这里默认不开启prettier格式化
  "prettier.enable": false,
  // 关闭默认格式化
  "editor.formatOnSave": false,

  // 保存自动修复
  "editor.codeActionsOnSave": {
    // 我们这里是指定自定义的修复
    "source.fixAll.eslint": "explicit",
    // 来源导入我们不需要给关闭掉
    "source.organizeImports": "never",
    // 使用 stylelint 来修复样式问题
    "source.fixAll.stylelint": "explicit",
    "source.fixAll.oxc": "always"
  },

  // 静默样式规则自动修复
  "eslint.rules.customizations": [
    { "rule": "style/*", "severity": "off", "fixable": true },
    { "rule": "format/*", "severity": "off", "fixable": true },
    { "rule": "*-indent", "severity": "off", "fixable": true },
    { "rule": "*-spacing", "severity": "off", "fixable": true },
    { "rule": "*-spaces", "severity": "off", "fixable": true },
    { "rule": "*-order", "severity": "off", "fixable": true },
    { "rule": "*-dangle", "severity": "off", "fixable": true },
    { "rule": "*-newline", "severity": "off", "fixable": true },
    { "rule": "*quotes", "severity": "off", "fixable": true },
    { "rule": "*semi", "severity": "off", "fixable": true }
  ],

  // 在eslin中开启哪些语言的校验
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "gql",
    "graphql",
    "astro",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
  // ✅ 显式指定 Node.js 路径（解决 ENOENT 核心）
  // "oxc.path.node": "C:\\Program Files\\nodejs\\node.exe", // Windows 典型路径
  // 如果你不确定路径，可以直接写 "node"（前提是 PATH 里有）
  // "oxc.path.node": "node",

  // ✅ 指定语言服务器二进制路径（官方推荐）
  "oxc.path.oxlint": "node_modules/oxlint/bin/oxc_language_server",

  // ✅ 基础开关
  "oxc.enable": false,
  // "oxc.lint.run": "onSave",
  "oxc.server.path": "npx",
  "oxc.server.args": ["oxlint", "--lsp"],
  "cSpell.words": [
    "aeac",
    "esno",
    "radash",
    "unplugin"
  ],
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSaveMode": "file",
  "[javascript]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
  },
  "[vue]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
  } // tell oxfmt to format the whole file, not only the modified lines
  // Or enable it for specific file types:
  // "[javascript]": {
  //   "editor.defaultFormatter": "oxc.oxc-vscode"
  // },
  //   // 拖拽行为
  //   "markdown.editor.drop.copyIntoWorkspace": "never",
  //   // 粘贴行为
  //   "markdown.editor.filePaste.copyIntoWorkspace": "never"
}
